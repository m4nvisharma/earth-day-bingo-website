# Server
PORT=4000
JWT_SECRET=replace-with-long-random-string
CORS_ORIGIN=https://your-username.github.io/your-repo
MAX_UPLOAD_MB=2

# Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase Storage (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_BUCKET=bingo-images

# Image optimization
IMAGE_MAX_WIDTH=1600
IMAGE_QUALITY=75
IMAGE_FORMAT=jpeg

# S3 compatible storage (optional but recommended for production)
S3_ENDPOINT=https://s3.your-provider.com
S3_REGION=auto
S3_BUCKET=your-bucket
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PUBLIC_BASE_URL=https://your-public-cdn-or-bucket-url

# Local uploads (dev fallback)
UPLOAD_DIR=uploads

# Storage monitoring (local uploads only)
# STORAGE_LIMIT_MB should match your Render disk limit in MB.
STORAGE_LIMIT_MB=1024
STORAGE_WARN_PERCENT=85
STORAGE_CRITICAL_PERCENT=95
STORAGE_ALERT_COOLDOWN_HOURS=24

# Admin
ADMIN_EMAIL=info@cycat.ca
PUBLIC_BACKEND_URL=https://your-backend.onrender.com
PUBLIC_FRONTEND_URL=https://your-username.github.io/your-repo
